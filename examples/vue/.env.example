# Vite exposes env vars with the VITE_ prefix — envcase strips it automatically.
# Schema key: API_URL → env var: VITE_API_URL
VITE_API_URL=  # string (url) — required
VITE_APP_TITLE=My App  # string — default: My App
VITE_ENABLE_ANALYTICS=false  # boolean — default: false
VITE_ENABLE_DARK_MODE=false  # boolean — default: false
