# ── Server-side (private) ─────────────────────────────────────────────────
# These are NOT prefixed with NEXT_PUBLIC_ — they stay on the server only.

DATABASE_URL=  # string (url) — required
API_SECRET=  # string (min 32 chars) — required
NODE_ENV=development  # "development" | "test" | "production" — default: development

# ── Client-side (public) ──────────────────────────────────────────────────
# NEXT_PUBLIC_* variables are baked into the browser bundle at build time.
# envcase strips the prefix so schema keys stay clean (APP_URL, not NEXT_PUBLIC_APP_URL).

NEXT_PUBLIC_APP_URL=  # string (url) — required
NEXT_PUBLIC_APP_TITLE=My App  # string — default: My App
NEXT_PUBLIC_ENABLE_ANALYTICS=false  # boolean — default: false
