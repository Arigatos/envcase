{
  "name": "envcase",
  "version": "0.1.1",
  "description": "Type-safe, framework-agnostic environment variable validation with Zod",
  "license": "MIT",
  "author": "Vasilis <vasilissavv@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arigatos/envcase.git",
    "directory": "packages/envcase"
  },
  "homepage": "https://github.com/Arigatos/envcase#readme",
  "bugs": {
    "url": "https://github.com/Arigatos/envcase/issues"
  },
  "keywords": [
    "env",
    "environment",
    "environment-variables",
    "validation",
    "zod",
    "typescript",
    "type-safe",
    "dotenv",
    "config",
    "vite",
    "deno",
    "node"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapters": {
      "import": "./dist/adapters/index.js",
      "require": "./dist/adapters/index.cjs"
    }
  },
  "bin": {
    "envcase": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "peerDependencies": {
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "zod": "^3.23.0"
  }
}
